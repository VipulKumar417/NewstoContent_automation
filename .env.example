# EpiCred Content Automation - Environment Variables
# Fill in your real API keys below

# Gemini API Keys (up to 3 keys - auto-rotates when quota exhausted)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# NewsData.io API Keys (up to 3 keys - auto-rotates when quota exhausted)
# Get from: https://newsdata.io (free: 200 req/day per key)
NEWSDATA_API_KEY_1=
NEWSDATA_API_KEY_2=
NEWSDATA_API_KEY_3=

# GNews API Key (single key)
# Get from: https://gnews.io (free: 100 req/day)
GNEWS_API_KEY=

# Numbeo API Key for City Cost of Living
# Get from: https://www.numbeo.com/api/
NUMBEO_API_KEY=

# Google OAuth credentials file path
GOOGLE_CREDENTIALS_PATH=credentials.json

# Flask settings
FLASK_SECRET_KEY=epicred-secret-2026
FLASK_DEBUG=true
FLASK_PORT=5000
